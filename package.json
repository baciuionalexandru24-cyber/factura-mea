{
  "name": "verifica-factura",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "validate:content": "node scripts/validate-editorial-content.cjs",
    "generate:seo": "npm run validate:content && node scripts/generate-content-assets.cjs",
    "generate:social": "npm run validate:content && node scripts/generate-social-assets.cjs",
    "generate:all": "npm run generate:seo && npm run generate:social",
    "prebuild": "npm run generate:all",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
